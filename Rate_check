# 1. LOAD SHAPEFILES AND PREPARE AREA CODES -----------------------------------
# World basemap
world <- ne_countries(scale = "medium", returnclass = "sf") %>%
  select(continent, geometry)

# ICES areas: read and add Area_Full to match prediction codes (lowercase)
ICES.areas <- st_read(dsn = "shapefiles/", layer = "ICES_Areas_20160601_cut_dense_3857") %>%
  mutate(Area_Full = tolower(Area_27))

# NAFO divisions: read, transform, and add Area_Full code
NAFO.areas <- st_read(dsn = "shapefiles/", layer = "NAFO_Divisions_2021_poly_clipped")
NAFO <- NAFO.areas %>%
  st_transform(st_crs(ICES.areas)) %>%
  mutate(
    Area_Full = paste0('21.', Division) %>%
      str_remove_all('-') %>%
      str_replace_all('([A-Z])', '.\1') %>%
      tolower()
  )

# 2. LOAD PREDICTION GRID ------------------------------------------------------
# CSV must have columns: fac_breeding_season ("Q2Q3" or "Q4Q1"), fac_Area_Full, pred_rate
pred <- fread("pred_grid.csv") %>%
  rename(
    quarter_split = fac_breeding_season,
    Area_Full     = fac_Area_Full
  ) %>%
  # ensure case alignment with shapefiles
  mutate(Area_Full = tolower(Area_Full),
         quarter_split = toupper(quarter_split))

# 3. SUMMARISE MEAN RATE BY AREA & SEASON ---------------------------------------
summary_rates <- pred %>%
  group_by(quarter_split, Area_Full) %>%
  summarise(mean_rate = mean(pred_rate, na.rm = TRUE), .groups = "drop")
#MEAN RATE BY AREA & SEASON -------------------------------------
  summary_rates <- pred %>%
  group_by(quarter_split, Area_Full) %>%
  summarise(mean_rate = mean(pred_rate, na.rm = TRUE), .groups = "drop")

# 4. MAP FUNCTION -------------------------------------------------------------
make_map <- function(season_label) {
  # filter summarized rates
  rates <- summary_rates %>% filter(quarter_split == season_label)
  
  # merge with spatial polygons
  sf_ices <- ICES.areas %>% left_join(rates, by = "Area_Full")
  sf_nafo <- NAFO      %>% left_join(rates, by = "Area_Full")
  
  ggplot() +
    # base polygons
    geom_sf(data = ICES.areas, fill = "white", color = NA) +
    geom_sf(data = NAFO,       fill = "white", color = NA) +
    # fill by mean_rate
    geom_sf(data = sf_ices, aes(fill = mean_rate), color = NA) +
    geom_sf(data = sf_nafo, aes(fill = mean_rate), color = NA) +
    # overlay land mask
    geom_sf(
      data = world %>% filter(continent %in% c("Europe", "North America")),
      fill = "black", color = "black", size = 0
    ) +
    coord_sf(
      crs  = st_crs(ICES.areas),
      xlim = c(-75, 40),
      ylim = c(33, 70),
      expand = FALSE
    ) +
    scale_fill_viridis_c(
      name     = "Bycatch rate\n(birds per hook)",
      na.value = "grey90"
    ) +
    labs(
      title = case_when(
        season_label == "Q2Q3" ~ "Breeding season (Q2–Q3)",
        season_label == "Q4Q1" ~ "Non-breeding (Q4–Q1)"
      )
    ) +
    theme_minimal() +
    theme(
      plot.title      = element_text(size = 14, face = "bold"),
      legend.position = "bottom",
      axis.title      = element_blank(),
      panel.grid      = element_blank(),
      panel.border    = element_rect(color = "black", fill = NA)
    )
}

# 5. CREATE AND SAVE PANEL OF TWO MAPS ---------------------------------------
map_breed    <- make_map("Q2Q3")
map_nonbreed <- make_map("Q4Q1")
combined <- map_breed + map_nonbreed +
