# function to plot residuals against all dependent variables
explore_residuals <- function(simres) {
  par(mfrow = c(3,3))
  plotResiduals(simres, rf$fac_year)
  plotResiduals(simres, rf$fac_month)
  plotResiduals(simres, rf$fac_breeding)
  plotResiduals(simres, rf$lat)
  plotResiduals(simres, rf$long)
  plotResiduals(simres, rf$distcoast_km)
  plotResiduals(simres, rf$distcolony_km)
  plotResiduals(simres, rf$fac_vessel)
  plotResiduals(simres, rf$nhooks)
  par(mfrow = c(1,1))
}

